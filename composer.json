{
  "name": "ssch/typo3-pagerfanta",
  "description": "Integrates pagerfanta into TYPO3",
  "type": "typo3-cms-extension",
  "require": {
    "pagerfanta/core": "^4.7",
    "typo3/cms-core": "^14.3",
    "typo3/cms-extbase": "^14.3",
    "typo3/cms-fluid": "^14.3",
    "webmozart/assert": "^2.1"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.2.5",
    "typo3/testing-framework": "^9.2.0",
    "php-parallel-lint/php-parallel-lint": "^1.3",
    "rector/rector": "^2.5.4",
    "phpstan/phpstan-phpunit": "^2.0.18",
    "phpstan/extension-installer": "^1.1",
    "saschaegerer/phpstan-typo3": "^3.0.1",
    "symfony/serializer": "^7.0",
    "symplify/easy-coding-standard": "^13.2.6",
    "phpstan/phpstan-strict-rules": "^2.0.11",
    "phpstan/phpstan-webmozart-assert": "^2.0.0",
    "phpspec/prophecy-phpunit": "^2.0",
    "jangregor/phpstan-prophecy": "^2.3.0",
    "typo3/cms-install": "^14.3",
    "typo3/minimal": "^14.3",
    "typo3/cms-tstemplate": "^14.3",
    "helhum/typo3-console": "^8.2",
    "typo3/cms-fluid-styled-content": "^14.3",
    "phpstan/phpstan-deprecation-rules": "^2.0.3"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Ssch\\Typo3Pagerfanta\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ssch\\Typo3Pagerfanta\\Tests\\": "Tests/"
    }
  },
  "authors": [
    {
      "name": "Sebastian Schreiber",
      "email": "me@schreibersebastian.de"
    }
  ],
  "config": {
    "vendor-dir": ".Build/vendor",
    "bin-dir": ".Build/bin",
    "preferred-install": {
      "typo3/cms": "source",
      "typo3/cms-core": "source",
      "*": "dist"
    },
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  },
  "scripts": {
    "analyze": "phpstan analyse --ansi --memory-limit=-1",
    "test-php-lint": [
      ".Build/bin/parallel-lint ./Classes/",
      ".Build/bin/parallel-lint ./Configuration/TCA/",
      ".Build/bin/parallel-lint ./Tests/"
    ],
    "lint-php": "parallel-lint Tests Classes Configuration",
    "check-style": "ecs check --ansi",
    "fix-style": [
      "ecs check --fix --ansi"
    ],
    "test-unit": [
      ".Build/bin/phpunit --configuration Build/UnitTests.xml"
    ],
    "test-functional": [
      ".Build/bin/phpunit --configuration Build/FunctionalTests.xml"
    ]
  },
  "extra": {
    "branch-alias": {
      "dev-master": "3.0.x-dev"
    },
    "typo3/cms": {
      "extension-key": "typo3_pagerfanta",
      "web-dir": ".Build/Web"
    }
  }
}
